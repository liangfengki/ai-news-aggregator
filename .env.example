# OpenRouter API Key (used for LLM news classification & translation)
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Operating hours (China Standard Time, UTC+8)
# Service is active during these hours; outside this window, background tasks
# stop and a maintenance page is shown. Default: 08:00-18:00
# OPERATING_START_HOUR=8
# OPERATING_END_HOUR=18
